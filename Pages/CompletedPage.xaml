<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolist_application.Pages.CompletedPage"
             Title="CompletedPage">
    <CollectionView x:Name="completedList"
                    SelectionMode="Single"
                    SelectionChanged="CompletedList_SelectionChanged"
                    ItemsLayout="VerticalList">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Padding="10" Margin="5" BackgroundColor="White" Stroke="LightGray" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Label Text="{Binding item_name}"
                           LineBreakMode="WordWrap"
                           MaxLines="2"
                           VerticalOptions="Center"
                           HorizontalOptions="StartAndExpand"
                           Margin="0" />
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>