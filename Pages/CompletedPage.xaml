<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolist_application.Pages.CompletedPage"
             Title="CompletedPage">
    <CollectionView x:Name="completedList"
                    SelectionMode="Single"
                    SelectionChanged="CompletedList_SelectionChanged"
                    ItemsLayout="VerticalList">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Padding="10"
                        Margin="5"
                        BackgroundColor="White"
                        Stroke="LightGray"
                        StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6"/>
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="*, Auto"
                          ColumnSpacing="15"
                          Padding="0,0,20,0">

                        <Label Grid.Column="0"
                               Text="{Binding item_name}"
                               LineBreakMode="WordWrap"
                               MaxLines="2"
                               VerticalOptions="Center"
                               Margin="0"/>

                        <Image Grid.Column="1"
                               Source="trash.png"
                               WidthRequest="20"
                               HeightRequest="20"
                               Aspect="AspectFit"
                               VerticalOptions="Center">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Delete_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>

                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>