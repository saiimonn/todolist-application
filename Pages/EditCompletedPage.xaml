<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todolist_application.Pages.EditCompletedPage"
             Title="EditCompletedPage">
    <VerticalStackLayout Padding="20" Spacing="12">

        <Entry x:Name="titleEntry"/>

        <Entry x:Name="detailEntry"/>

        <Button Text="Update" Clicked="Update_Clicked" Margin="0,6,0,0" />

        <Button Text="Incomplete" Clicked="Incomplete_Clicked"
                BackgroundColor="Gray" Margin="0,6,0,0" />

        <Button Text="Delete" Clicked="Delete_Clicked"
                BackgroundColor="Pink" Margin="0,6,0,0" />

    </VerticalStackLayout>
</ContentPage>